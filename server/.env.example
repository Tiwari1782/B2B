# MongoDB Atlas Connection
NODE_ENV=development
MONGO_URI=<your-mongodb-atlas-uri>

# JWT Authentication (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=<your-jwt-secret>

# Cloudinary Image Hosting
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# CORS Allowed Origin
CLIENT_URL=http://localhost:5173

# Groq AI (LLaMA 3 Chatbot)
GROQ_API_KEY=<your-groq-key>

# Server Port
PORT=5000

# Nodemailer SMTP (Partnership Form Emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=<your-email>
SMTP_PASS=<your-app-password>
PARTNERSHIP_EMAIL=<your-email>

# SuperAdmin seed password (required for seed.js)
SUPERADMIN_PASSWORD=<set-a-strong-password>
SUPERADMIN_EMAIL=superadmin@bug2build.in
